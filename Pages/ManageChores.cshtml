@page
@model ManageChoresModel
@{
    ViewData["Title"] = "Manage Chores";
}

<div class="container">
    <h1>@ViewData["Title"]</h1>

    <div class="card mb-4 mt-5">
        <div class="card-header">
            <h5>Add New Chore</h5>
        </div>
        <div class="card-body">
            <form method="post">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label for="newName" class="form-label">Chore Name</label>
                        <input type="text" class="form-control" id="newName" name="newName" placeholder="e.g., Clean the gutters" required />
                    </div>
                    <div class="col-md-6">
                        <label for="newDays" class="form-label">Frequency (days)</label>
                        <input type="number" class="form-control" id="newDays" name="newDays" placeholder="e.g., 30" min="1" required />
                    </div>
                </div>
                <div class="row mt-3">
                    <div class="col">
                        <button type="submit" class="btn btn-primary">Add Chore</button>
                    </div>
                </div>
            </form>
            @if (!ModelState.IsValid)
            {
                <div class="alert alert-danger mt-3">
                    @foreach (var error in ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <p>@error.ErrorMessage</p>
                    }
                </div>
            }
        </div>
    </div>

    @if (Model.Chores.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Name</th>
                        <th>Frequency</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var chore in Model.Chores)
                    {
                        <tr>
                            <td>@chore.Name</td>
                            <td>@chore.Frequency.TotalDays days</td>
                            <td>
                                <button type="button" class="btn btn-sm btn-warning" data-bs-toggle="modal" data-bs-target="#editModal-@chore.Id">Edit</button>
                                <form method="post" style="display:inline;">
                                    <input type="hidden" name="choreId" value="@chore.Id" />
                                    <button type="submit" class="btn btn-sm btn-danger" formaction="?handler=Delete" onclick="return confirm('Are you sure?')">Delete</button>
                                </form>
                            </td>
                        </tr>

                        <!-- Edit Modal -->
                        <div class="modal fade" id="editModal-@chore.Id" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title">Edit Chore</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                    </div>
                                    <form method="post">
                                        <div class="modal-body">
                                            <input type="hidden" name="choreId" value="@chore.Id" />
                                            <div class="mb-3">
                                                <label for="editName-@chore.Id" class="form-label">Chore Name</label>
                                                <input type="text" class="form-control" id="editName-@chore.Id" name="editName" value="@chore.Name" required />
                                            </div>
                                            <div class="mb-3">
                                                <label for="editDays-@chore.Id" class="form-label">Frequency (days)</label>
                                                <input type="number" class="form-control" id="editDays-@chore.Id" name="editDays" value="@((int)chore.Frequency.TotalDays)" min="1" required />
                                            </div>
                                            <div class="mb-3">
                                                <label for="editDescription-@chore.Id" class="form-label">Description</label>
                                                <textarea class="form-control" id="editDescription-@chore.Id" name="editDescription">@chore.Description</textarea>
                                            </div>
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                            <button type="submit" class="btn btn-primary" formaction="?handler=Edit">Save Changes</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info" role="alert">
            No chores yet.
        </div>
    }
</div>
